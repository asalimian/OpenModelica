// name: slice_for
// keywords: NewBackend, algebraic loop, slice
// status: correct
// cflags: --newBackend

loadString("
model slice_for
  Real x[4];
  Real y[3];
equation
  x[1] = 1;
  for i in 1:3 loop
    y[i] = x[i] + x[i+1];
    y[4-i] + x[i+1] = 1;
  end for;
end slice_for;
"); getErrorString();

setCommandLineOptions("-d=dumpSimCode"); getErrorString();
simulate(slice_for); getErrorString();

