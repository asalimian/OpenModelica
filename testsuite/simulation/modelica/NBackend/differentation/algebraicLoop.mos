// name: algebraicLoop
// keywords: NewBackend
// status: correct

loadString("
  model algebraicLoop
    Real x, y;
  equation
    der(y)^3 + der(x)^2 - x * y = 0;
    der(x)^3 - der(y)^2 - y - x = 0;
  end algebraicLoop;
"); getErrorString();

setCommandLineOptions("--newBackend --generateDynamicJacobian=symbolic -d=dumpSimCode"); getErrorString();

buildModel(algebraicLoop); getErrorString();

